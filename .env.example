# Database Configuration
DB_URL=jdbc:mysql://mysql-db:3306/civic_system?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your-secure-password-here
DB_POOL_SIZE=10
DB_MIN_IDLE=5

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-min-256-bits-long-change-this
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8080
LOG_LEVEL=INFO

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# CORS Configuration (Update for production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-domain.com

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080